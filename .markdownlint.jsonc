{
  // Allow longer lines in templates and generated content
  "MD013": false,
  // Allow HTML in markdown (needed for comments and templates)
  "MD033": false,
  // Allow duplicate headings across different files
  "MD024": { "siblings_only": true },
  // Do not treat YAML front matter title as a heading (needed for Jekyll site pages)
  "MD025": { "front_matter_title": "" },
  // Allow trailing punctuation in headings (needed for "?")
  "MD026": false,
  // Sprint research and public-copy drafts use dense tables, citation markers,
  // and paste-ready snippets; keep CI focused on blocking structural issues.
  "MD028": false,
  "MD032": false,
  "MD034": false,
  "MD036": false,
  "MD040": false,
  "MD052": false,
  "MD060": false,
  "MD056": false
}
